# SafePath backend environment — copy this file to backend/.env and fill in real values.
# backend/.env is gitignored; this .env.example IS committed as the template.

# PostgreSQL connection string. Host is localhost when running the backend on your
# machine against the Docker Compose database (which publishes port 5432).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://safepath:changeme@localhost:5432/safepath

# Credentials the Postgres/PostGIS container is created with (used by docker-compose).
# Keep these in sync with the user:password embedded in DATABASE_URL above.
POSTGRES_USER=safepath
POSTGRES_PASSWORD=changeme

# Anthropic API key (placeholder for later phases; not used in Phase 0).
ANTHROPIC_API_KEY=your-anthropic-api-key-here
