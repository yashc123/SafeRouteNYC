# SafeRouteNYC — PRODUCTION environment (single-instance Docker Compose).
# Copy to .env.prod on the server and fill in REAL values. .env.prod is gitignored.
#
# Bring the stack up with:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- PostgreSQL / PostGIS (the "db" service) ---
POSTGRES_USER=safepath
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password
POSTGRES_DB=safepath

# --- Backend (FastAPI) ---
# NOTE: the host is the compose SERVICE NAME "db" (not localhost) — the backend
# runs inside the compose network. The password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://safepath:CHANGE_ME_to_a_strong_password@db:5432/safepath
# Redis service name is "redis".
REDIS_URL=redis://redis:6379/0
# Anthropic key for the /agent endpoint (backend-only — never exposed to the browser).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# MapTiler key for the backend geocode tool.
MAPTILER_KEY=REPLACE_ME_maptiler_key
# Optional NYC Open Data (Socrata) token for faster ingestion; leave blank if none.
SOCRATA_APP_TOKEN=
# Redis cache TTL in seconds (default 6h).
CACHE_TTL_SECONDS=21600
# Allowed browser origin(s). With the nginx proxy the app is same-origin, so this
# is belt-and-suspenders — set it to your public URL.
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN

# --- Frontend (baked into the static build AT IMAGE-BUILD TIME by Vite) ---
# MapTiler key for the map tiles + in-browser geocoding. This one is PUBLIC (it
# ends up in the JS bundle) — restrict it by domain in the MapTiler dashboard.
VITE_MAPTILER_KEY=REPLACE_ME_maptiler_key
# API base path. Leave as /api — nginx proxies /api/* to the backend.
VITE_API_URL=/api
