# SafePath backend environment — copy this file to backend/.env and fill in real values.
# backend/.env is gitignored; this .env.example IS committed as the template.

# PostgreSQL connection string. Host is localhost when running the backend on your
# machine against the Docker Compose database (which publishes port 5432).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://safepath:changeme@localhost:5432/safepath

# Credentials the Postgres/PostGIS container is created with (used by docker-compose).
# Keep these in sync with the user:password embedded in DATABASE_URL above.
POSTGRES_USER=safepath
POSTGRES_PASSWORD=changeme

# Anthropic API key — required for the Phase 8 agent (POST /agent). Get one at
# https://console.anthropic.com/. Without it, /agent returns 503 (rest of app works).
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MapTiler key for the agent's server-side geocode tool (same key as the frontend).
MAPTILER_KEY=your-maptiler-api-key-here

# Optional: free NYC Open Data (Socrata) app token for higher rate limits during
# Phase 2 ingestion. Leave blank to run without one (works, just rate-limited).
# Get one at https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Redis (tier-3 cache) connection URL. Points at the docker-compose redis service.
REDIS_URL=redis://localhost:6379/0

# How long cached /route and /reachable results live, in seconds (default 6h).
# Safety weights are recomputed only when new data is ingested, so a long TTL is
# fine; shorten it if you retune the model frequently.
CACHE_TTL_SECONDS=21600

# Comma-separated browser origins allowed by CORS (the Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
