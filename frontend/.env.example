# SafePath frontend environment — copy this file to frontend/.env and fill in real values.
# frontend/.env is gitignored; this .env.example IS committed as the template.
#
# Vite only exposes variables prefixed with VITE_ to the browser.
# No surrounding quotes — the value is used verbatim.

VITE_MAPTILER_KEY=your-maptiler-api-key-here
