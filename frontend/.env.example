# SafeRouteNYC frontend environment — copy this file to frontend/.env and fill in real values.
# frontend/.env is gitignored; this .env.example IS committed as the template.
#
# Vite only exposes variables prefixed with VITE_ to the browser.
# No surrounding quotes — the value is used verbatim.

VITE_MAPTILER_KEY=your-maptiler-api-key-here

# Base URL of the SafeRouteNYC backend API. Defaults to http://localhost:8000 if unset.
# Set this to the deployed API URL for production (AWS) later.
VITE_API_URL=http://localhost:8000
